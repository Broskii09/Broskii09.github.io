{
  "name": "omjn-test",
  "version": "1.0.0",
  "description": "Playwright tooling for the OMJN TEST build.",
  "main": "operator.js",
  "scripts": {
    "serve:test": "node scripts/static-server.cjs --port 3000",
    "test": "playwright test",
    "test:smoke": "playwright test tests/omjn-smoke.spec.js",
    "test:smoke:headed": "playwright test tests/omjn-smoke.spec.js --headed",
    "test:special-slots": "playwright test tests/omjn-special-slots.spec.js",
    "test:queue-state": "playwright test tests/omjn-queue-state.spec.js",
    "test:media-houseband": "playwright test tests/omjn-media-and-houseband.spec.js",
    "test:smoke:all": "playwright test tests/omjn-smoke.spec.js tests/omjn-special-slots.spec.js tests/omjn-queue-state.spec.js tests/omjn-media-and-houseband.spec.js tests/omjn-timer-overtime.spec.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
